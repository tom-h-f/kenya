R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-s3-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-s3-secret-access-key
R2_BUCKET=kenya-monitor-2027

# X (Twitter) Scraper Backend Selection: "twscrape" or "apify"
X_BACKEND=twscrape
# Required only if X_BACKEND=apify
APIFY_TOKEN=your-apify-token
# Optional: "xquik/x-tweet-scraper" (default) or "apidojo/tweet-scraper"
APIFY_ACTOR_ID=xquik/x-tweet-scraper

# Account pool throughput (collector on pi0). Defaults suit ~50+ twscrape accounts.
# REQUEST_DELAY_MIN/MAX apply per scraping account between its own requests.
COLLECT_CONCURRENCY=3
POSTS_MIN_GAP_HOURS=3
POSTS_MAX_GAP_HOURS=5
METRICS_MAX_POSTS_PER_ACCOUNT=8
METRICS_MAX_POSTS_FLOOR=200
ACCOUNT_SYNC_HOURS=6

# Search / snowball / adaptive (see docs/collection/README.md)
SEARCH_INCLUDE_RETWEETS=1
SEARCH_PRODUCT=Latest
SNOWBALL_TOP_RETWEETED=15
SNOWBALL_REFRESH_HOURS=12
DYNAMIC_MAX_KEYWORDS=10
DYNAMIC_MAX_ACCOUNTS=20
BURST_ZSCORE=3.0

# Follow graph collection
FOLLOW_FETCH_LIMIT=500
FOLLOW_MAX_ACCOUNTS=30
FOLLOW_CRAWL_MAX_PER_RUN=50
FOLLOW_CRAWL_REFRESH_DAYS=30
