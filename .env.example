R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-s3-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-s3-secret-access-key
R2_BUCKET=kenya-monitor-2027

# DuckDB quack server (tf1)
QUACK_TOKEN=generate-with-openssl-rand-hex-24
QUACK_HOST=tf1.meerkat-decibel.ts.net:9494

# X (Twitter) Scraper Backend Selection: "twscrape" or "apify"
X_BACKEND=twscrape
# Required only if X_BACKEND=apify
APIFY_TOKEN=your-apify-token
# Optional: "xquik/x-tweet-scraper" (default) or "apidojo/tweet-scraper"
APIFY_ACTOR_ID=xquik/x-tweet-scraper
